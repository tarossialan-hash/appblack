<?xml version="1.0" encoding="utf-8"?>
<!--
  Marca Λ da BLACK desenhada em vetor.
  O ícone anterior vinha de um PNG de 72x72 ampliado, e ampliação não recria
  detalhe — daí o aspecto borrado na tela inicial. Em vetor a forma é
  rasterizada na resolução exata de cada densidade, sempre nítida.

  Viewport de 108dp = canvas do ícone adaptativo. A marca ocupa a zona segura
  central (~66dp), então nada é cortado pela máscara circular do launcher.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Brilho suave atrás da marca, dando profundidade sem borrar a forma -->
    <path
        android:pathData="M54,30 L88,82 L20,82 Z"
        android:fillAlpha="0.10">
        <aapt:attr name="android:fillColor" xmlns:aapt="http://schemas.android.com/aapt">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="60"
                android:gradientRadius="40"
                android:startColor="#FFFFFFFF"
                android:endColor="#00FFFFFF" />
        </aapt:attr>
    </path>

    <!--
      Chevron com hastes que afinam em direção ao ápice:
      as arestas externas partem de (54,26) e as internas só começam em (54,52),
      então a espessura cresce de cima para baixo, como na logomarca.
    -->
    <path android:pathData="M54,26 L86,82 L71,82 L54,52 L37,82 L22,82 Z">
        <aapt:attr name="android:fillColor" xmlns:aapt="http://schemas.android.com/aapt">
            <gradient
                android:type="linear"
                android:startX="30"
                android:startY="26"
                android:endX="78"
                android:endY="82"
                android:startColor="#FFFFFFFF"
                android:centerColor="#FFD8DCE0"
                android:endColor="#FF8E969E" />
        </aapt:attr>
    </path>

    <!-- Realce no topo: reproduz o ponto de luz do ápice da logo original -->
    <path
        android:pathData="M54,26 L62,40 L54,36 L46,40 Z"
        android:fillColor="#FFFFFFFF"
        android:fillAlpha="0.85" />
</vector>
